{
  "name": "hush",
  "version": "0.10.0",
  "description": "Per-site element hiding, DOM removal, and network blocking for Chrome (MV3)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wasm-pack build --target web --out-dir dist/pkg --no-typescript",
    "build:dev": "wasm-pack build --target web --out-dir dist/pkg --no-typescript --dev",
    "test": "npm run build && node --test test/*.mjs",
    "test:rust": "cargo test"
  }
}
