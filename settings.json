{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(endless-cli *)",
      "Bash(curl*localhost:15702*)",
      "Bash(*llm-player*python*actions.py*)",
      "Bash(gh *)",
      "Bash(cd /c/code/*cargo *)",
      "Bash(cd /c/code/*git *)",
      "Bash(cd /c/code/*wc *)",
      "Bash(ls *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "~/.claude/sanitizer/sanitizer.json",
      "~/.claude/unsanitized/**"
    ],
    "filePermissions": {
      "denyRules": [
        ".env",
        ".env.*",
        "**/.env",
        "**/secrets/**",
        "**/*.key",
        "**/*.pem",
        "**/credentials/**"
      ]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -NoProfile -File \"$USERPROFILE/.claude/hooks/Hook-SessionStart-Skills.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [],
    "PostToolUse": []
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      ""
    ]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "ENABLE_LSP_TOOL": "1"
}
